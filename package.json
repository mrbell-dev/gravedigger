    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "fast-check": "^3.23.1",
    "playwright": "^1.61.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.1.8"
